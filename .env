# GitLab
GITLAB_URL=https://gitlab.nebiz.net
GITLAB_TOKEN=your_private_token_here
REG_TOKEN=your_registration_token_here
# Автоскейлинг
MIN_RUNNERS=0
MAX_RUNNERS=5
CHECK_INTERVAL=30
PROJECTS_LIMIT=20

# Cooldown (защита от дребезга)
SCALE_UP_COOLDOWN=30
SCALE_DOWN_COOLDOWN=60

# Пороги ресурсов хоста
CPU_THRESHOLD=80.0
RAM_THRESHOLD=80.0

# Graceful shutdown
GRACEFUL_PERIOD=300

# Раннер
RUNNER_IMAGE=gitlab/gitlab-runner:latest
RUNNER_CONCURRENT=2
RUNNER_TAGS=shared_runner

# Профиль по умолчанию
DEFAULT_RUNNER_PROFILE=medium

# Профили раннеров (small/medium/large)
# small
PROFILE_SMALL_CPU_LIMIT=0.5
PROFILE_SMALL_MEMORY_LIMIT=512m
PROFILE_SMALL_CONCURRENT=1
PROFILE_SMALL_TAGS=small

# medium
PROFILE_MEDIUM_CPU_LIMIT=1.0
PROFILE_MEDIUM_MEMORY_LIMIT=1024m
PROFILE_MEDIUM_CONCURRENT=2
PROFILE_MEDIUM_TAGS=medium

# large
PROFILE_LARGE_CPU_LIMIT=2.0
PROFILE_LARGE_MEMORY_LIMIT=2048m
PROFILE_LARGE_CONCURRENT=4
PROFILE_LARGE_TAGS=large

# Метрики Prometheus
METRICS_PORT=8000